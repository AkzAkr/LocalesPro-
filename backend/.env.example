# Salin file ini menjadi backend/.env sebelum deploy ke hosting.
# Jangan commit backend/.env ke repository.

LOCALESPRO_APP_ENV=production

# Database hosting (sesuaikan dengan panel cPanel / hosting Anda)
DB_HOST=localhost
DB_NAME=locales_db
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# WAJIB di production: buat string acak panjang (min. 32 karakter)
LOCALESPRO_JWT_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG_MIN_32_KARAKTER
LOCALESPRO_JWT_ISSUER=localespro-backend
LOCALESPRO_JWT_AUDIENCE=localespro-frontend

# Origin frontend yang diizinkan (pisahkan dengan koma).
# Kosongkan jika frontend & backend satu domain (same-origin).
# Contoh: https://pos.domainanda.com,https://www.domainanda.com
LOCALESPRO_CORS_ORIGINS=

# Path aplikasi di URL (opsional, untuk konfigurasi lokal)
LOCALESPRO_APP_PATH=/
